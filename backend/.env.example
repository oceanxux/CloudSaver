# JWT配置
JWT_SECRET=your_jwt_secret_here

# 登录配置
CLOUDSAVER_USERNAME=admin
CLOUDSAVER_PASSWORD=admin123456

# Telegram配置
TELEGRAM_BASE_URL=https://t.me/s

# Telegram频道配置
# 留空或设为 [] 时，会自动使用内置的天翼云盘频道
TELE_CHANNELS=[]

# 可选代理配置
PROXY_ENABLED=false
HTTP_PROXY_HOST=127.0.0.1
HTTP_PROXY_PORT=7890

# 天翼搜 Cloudflare 挑战兼容
# 方案 1：直接填浏览器里拿到的 Cookie（至少包含 cf_clearance）
TIANYISO_COOKIE=
# 可选：如果 Cookie 对 UA 绑定，填与取 Cookie 时一致的浏览器 UA
TIANYISO_USER_AGENT=

# 方案 2：接入 FlareSolverr / FlareBypasser 兼容 API
# 例如：http://127.0.0.1:8191/v1
TIANYISO_SOLVER_URL=
TIANYISO_SOLVER_SESSION=
TIANYISO_SOLVER_TIMEOUT_MS=120000
TIANYISO_SOLVER_WAIT_SECONDS=2
TIANYISO_SOLVER_TABS_TILL_VERIFY=0
